# Copiar a .env.ferozo y completar (no se sube a git).
# Deploy automatizado: npm run deploy:ferozo  —  o  scripts\deploy-ferozo.bat

# ─── Build (Vite) ───────────────────────────────────────────────────────────

# Dominio principal de este deploy (canonical SEO)
VITE_SITE_URL=https://www.emprenor.com.ar

# Misma base de datos que Vercel (Supabase)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# API serverless compartida (formularios + email admin desde .com.ar)
VITE_API_ORIGIN=https://grupo.emprenor.com

# ─── FTP Ferozo (cPanel → Cuentas FTP) ─────────────────────────────────────

# Host FTP (ej. c2751446.ferozo.com o ftp.emprenor.com.ar)
FTP_HOST=
FTP_USER=
FTP_PASS=

# Directorio remoto (casi siempre public_html en Ferozo)
FTP_REMOTE_DIR=/public_html

# Puerto (21 FTP, 990 FTPS implícito — consulte panel Ferozo)
FTP_PORT=21

# true = FTPS explícito (puerto 21 + AUTH TLS). false = FTP plano
FTP_SECURE=false

# true = log detallado de la sesión FTP
# FTP_VERBOSE=false
