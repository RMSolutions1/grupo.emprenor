# Sitio público
VITE_SITE_URL=https://grupo.emprenor.com

# API serverless (mismo backend para .com y .com.ar)
# VITE_API_ORIGIN=https://grupo.emprenor.com

# Supabase — panel de administración y contenido dinámico
# Crear proyecto en https://supabase.com y ejecutar scripts/supabase-schema.sql
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# En Vercel (Settings → Environment Variables) — marcar Production, Preview y Development
# Las tres son obligatorias para formularios + panel admin en producción
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# Opcional en Vercel (la API usa VITE_SUPABASE_URL si no está definida)
# SUPABASE_URL=https://tu-proyecto.supabase.co

# Correo corporativo Ferozo (SMTP) — preferido para respuestas desde el panel
# Si SMTP está configurado, se usa en lugar de Resend
SMTP_HOST=c2751446.ferozo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@emprenor.com.ar
SMTP_PASS=tu-contraseña-del-buzón
MAIL_FROM=EMPRENOR <info@emprenor.com.ar>
MAIL_REPLY_TO=info@emprenor.com.ar
STAFF_NOTIFY_EMAIL=info@emprenor.com.ar
ADMIN_PANEL_URL=https://grupo.emprenor.com/admin/consultas
# Webhook Supabase → aviso email (opcional, formularios vía RPC en .com.ar)
# INBOX_WEBHOOK_SECRET=generar-token-seguro

# Alternativa: Resend (solo si no usa SMTP)
# RESEND_API_KEY=re_xxxx

# Solo local / scripts — misma clave que arriba

# Crear admin (tsx scripts/create-admin.ts) — contraseña obligatoria
# SEED_ADMIN_EMAIL=admin@emprenor.com.ar
# SEED_ADMIN_PASSWORD=tu-password-segura

# Alternativa al service role para seed
# SEED_ADMIN_EMAIL=admin@emprenor.com.ar
# SEED_ADMIN_PASSWORD=tu-password
